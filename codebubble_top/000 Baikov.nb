       RowBox[{
        SubscriptBox["l", "i"], ".", 
        SubscriptBox["q", "j"]}]]}]}]}], " ", "=", " ", 
   RowBox[{
    RowBox[{"\[Sum]", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          RowBox[{"\[PartialD]", 
           SubscriptBox["l", "m"]}], ".", 
          SubscriptBox["q", "j"]}], 
         RowBox[{"\[PartialD]", 
          SubscriptBox["z", "k"]}]], ")"}], 
       RowBox[{"-", "1"}]], ".", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        SubscriptBox["z", "k"]], "           ", 
       SubscriptBox["q", "i"]}], ".", 
      SubscriptBox["q", "j"]}]}], "=", 
    RowBox[{"G00", "[", 
     RowBox[{"[", 
      RowBox[{"i", ",", "j"}], "]"}], "]"}]}]}]}]], "Input",
