Cell["\<\
{{(-2*(1 - 4*mu^2 + 2*v0 + 4*a*mu*v0)*(v0 - 2*v1)*Log[k1] + (4*a*mu*v0*(v0 - \
2*v1) + (1 + 2*v0)*(1 + 4*v0 + 2*v0^2 - 2*v1) + mu^2*(-4 - 8*v0 + 8*v1))*
     Log[-k0^2 + k1^2])/(8*mu^2 - 2*(1 + 2*v0)^2), (-I)*(v0 - \
2*v1)*ArcTanh[k1/k0]}, 
 {((2*I)*v0*(2*k0*(4*v1^3*(1 - 2*a*mu + v1) + 4*v0*v1*(1 - 4*mu^2 + v1 + \
2*a*mu*v1) + v0^2*(1 + 4*mu^2 + 4*v1 + 4*a*(mu + 2*mu*v1))) + 
     k1*(1 + 8*v0 + 22*v0^2 + 24*v0^3 + 8*v0^4 + 8*a*mu^3*(1 + 2*v0 - 2*v1) - \
4*mu^2*(1 + 4*v0 + 6*v0^2 - 2*v1) - 2*v1 - 8*v0^2*v1 - 32*v0*v1^3 - 
       2*a*mu*(1 + 2*v0)*(1 - 2*v1 + 4*v0*(1 + \
v1)))*ArcTanh[k1/k0]))/(k1*(-4*mu^2 + (1 + 2*v0)^2)^2), 
  ((-4*mu^2*(1 + v0) + 4*a*mu*v0*(v0 - 2*v1) + (1 + 2*v0)*(1 + v0*(3 + \
4*v1)))*Log[k1] + v0*(1 - 2*a*mu + 2*v0)*(v0 - 2*v1)*Log[-k0^2 + k1^2])/
   (4*mu^2 - (1 + 2*v0)^2)}}\
\>", "Output",
